<script>
    // Show Referral Code Pop-up
    function showReferralPopup() {
      document.getElementById('referralModal').style.display = "block";
    }
  
    // Close the Referral Code Pop-up
    function closeReferralPopup() {
      document.getElementById('referralModal').style.display = "none";
    }
  
    // Copy the Referral Code
    function copyReferralCode() {
      const copyText = document.getElementById("referralCodeInput");
      copyText.select();
      copyText.setSelectionRange(0, 99999); // For mobile devices
      document.execCommand("copy");
  
      // Optional: Alert user that the code was copied
      alert("Referral code copied: " + copyText.value);
    }
    function signOut() {
    // Delete the token and auth cookies
    deleteCookie('token');
    deleteCookie('auth');

    // Optionally, redirect the user to the login page or home page
    window.location.href = '/home';  // or any other page
}
</script>
