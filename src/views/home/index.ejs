function generateWithdrawalRows() {
  const container = document.getElementById('withdrawalRows');
  if (!container) return;

  const methods = ['UPI', 'Paytm', 'PhonePe', 'Bank Transfer', 'IMPS'];
  const statuses = [
    { label: 'Success', color: '#22c55e' },
    { label: 'Success', color: '#22c55e' },
    { label: 'Success', color: '#22c55e' },
    { label: 'Pending', color: '#f59e0b' },
    { label: 'Rejected', color: '#ef4444' },
  ];

 function randomDate() {
  const now = new Date();

  // 95% Today, 5% Yesterday
  const dayOffset = Math.random() < 0.95 ? 0 : 1;

  const d = new Date(now);
  d.setDate(now.getDate() - dayOffset);

  let hours = Math.floor(Math.random() * 12) + 1;
  let mins = Math.floor(Math.random() * 60);
  let ampm = Math.random() > 0.5 ? "AM" : "PM";

  const months = [
    "Jan","Feb","Mar","Apr","May","Jun",
    "Jul","Aug","Sep","Oct","Nov","Dec"
  ];

  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}, ${String(hours).padStart(2,"0")}:${String(mins).padStart(2,"0")} ${ampm}`;
}

  function randomAmount() {
    const amounts = [500, 1000, 1500, 2000, 2500, 3000, 5000, 7500, 10000, 15000, 20000];
    return amounts[Math.floor(Math.random() * amounts.length)].toLocaleString('en-IN');
  }

  const rows = [];
  for (let i = 0; i < 5; i++) {
    const method = methods[Math.floor(Math.random() * methods.length)];
    const status = statuses[Math.floor(Math.random() * statuses.length)];
    rows.push({ date: randomDate(), amount: randomAmount(), method, status });
  }

  rows.sort((a, b) => new Date(b.date) - new Date(a.date));

  container.innerHTML = rows.map(r => `
    <div style="display:grid; grid-template-columns:2fr 1.1fr 1.2fr 1fr; padding:11px 0; border-bottom:1px solid #2a2a3a; align-items:center;">
      <span style="color:#ccc; font-size:11.5px; line-height:1.4;">${r.date}</span>
      <span style="color:#fff; font-size:12px; font-weight:500;">₹${r.amount}</span>
      <span style="color:#ccc; font-size:12px;">${r.method}</span>
      <span style="color:${r.status.color}; font-size:12px; font-weight:500;">${r.status.label} ›</span>
    </div>
  `).join('');
}



