    <script>
     function openGame(gameId) {
        // loader show
      document.getElementById("pageLoader").style.display = "flex";
      console.log("Opening game with ID:", gameId);
    axios.post('/get-int-url', {
      gameId: gameId
    })
    .then(res => {
      console.log(res.data);

      // agar URL return ho raha hai to redirect
      if(res.data){
        window.location.href = res.data.message; // assuming the URL is in res.data.message
        document.getElementById("pageLoader").style.display = "none";

      }else{
        document.getElementById("pageLoader").style.display = "none";
        alert("Game URL not found.");
      }
    })
    .catch(err => {
      document.getElementById("pageLoader").style.display = "none";
      console.error(err);
    });
  }


   // all games from backend
  const allGames = <%- JSON.stringify(gameData.games || []) %>;

  let currentCategory = "Popular";



  // default render
  window.onload = () => {
    renderGames("Popular");
  };



  // category select
  function selectCategory(category, el) {

    currentCategory = category;

    // active class remove
    document.querySelectorAll(".fun-tab-item")
      .forEach(item => item.classList.remove("activeClassName"));

    document.querySelectorAll(".tab_item")
      .forEach(item => item.classList.remove("tab_active"));

      document.getElementById("gameListTitle").innerText = category ;

    // active class add
    el.classList.add("activeClassName");

    const tab = el.querySelector(".tab_item");

    if(tab){
      tab.classList.add("tab_active");
    }

    renderGames(category);
  }



  // render games
  function renderGames(category) {

    const gameList = document.getElementById("gameList");

    let filtered = [];

    if(category === "Popular"){
      filtered = allGames.filter(
        g => g.category === "Popular"
      );
    } else {

      filtered = allGames.filter(
        g => g.category?.toLowerCase() === category.toLowerCase()
      );

    }


    gameList.innerHTML = filtered.map(item => {

      return `

        <div
          data-v-d06787cb=""
          onclick="${
            item.route
              ? `window.location.href='${item.route}'`
              : `openGame('${item.gameID}')`
          }"
        >

          <div data-v-d06787cb="" class="item">

            <img
              data-v-d06787cb=""
              src="${item.img}"
              alt=""
            />

          </div>

          <div data-v-d06787cb="" class="win-odds">

            <span data-v-d06787cb="">RTP</span>

            <span data-v-d06787cb="">95.11%</span>

            <div
              data-v-d06787cb=""
              class="win-p"
              style="width:95.11%"
            ></div>

          </div>

        </div>

      `;

    }).join("");

  }





